# Environment Configuration
# Copy this file to .env and update with your values

# Application
PROJECT_NAME=AgriVisionTalk API
ENVIRONMENT=development
DEBUG=True
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://agrivision:agrivision123@localhost:5432/agrivision_db

# JWT Secret (CHANGE IN PRODUCTION!)
SECRET_KEY=your-secret-key-change-in-production-min32chars-random-string-here!
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# AI Models
MODEL_PATH=../p1/models/best_model.pth
MODEL_METADATA_PATH=../p1/models/metadata.json
DEVICE=cuda

# Weather API (Get free API key from openweathermap.org)
WEATHER_API_KEY=your-openweathermap-api-key-here
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# HuggingFace (Optional - for RAG chatbot)
HUGGINGFACE_API_KEY=your-huggingface-api-key-here
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# FAISS Vector DB
FAISS_INDEX_PATH=./data/faiss_index
KNOWLEDGE_BASE_PATH=./data/knowledge_base

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379/0

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
